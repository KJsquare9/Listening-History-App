@startuml C4_Component_API
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Component Diagram — Parse & Enrich API (Flask)

Container_Boundary(api, "Parse & Enrich API") {

    Component(user_router, "User Upload Router", "Flask Blueprint (/api/parse)", "Accepts single-user listening history file. Detects format. Delegates to parser registry. Returns enriched events + cohort comparison.")

    Component(researcher_router, "Researcher Router", "Flask Blueprint (/api/researcher/*)", "Handles /api/researcher/demo (return demo dataset) and /api/researcher/process (upload + process multi-participant data).")

    Component(metadata_validator, "Metadata Validator", "Python module", "Validates researcher metadata CSV. Checks for required fields (Participant_ID, etc). Matches participant files to metadata rows by Participant_ID.")

    Component(registry, "Parser Registry", "Python module", "Maps format identifiers (spotify, ytmusic, csv, ...) to parser classes. Used by both user and researcher routes.")

    Component(spotify_parser, "Spotify Parser", "Parser plugin", "Reads Spotify StreamingHistory JSON. Outputs NormalisedEvent list: track, artist, timestamp, ms_played.")

    Component(yt_parser, "YT Music Parser", "Parser plugin", "Reads YT Music Takeout JSON. Outputs NormalisedEvent list.")

    Component(csv_parser, "Generic CSV Parser", "Parser plugin", "Reads tabular track / timestamp / ms_played data. Outputs NormalisedEvent list.")

    Component(enricher, "Track Enricher", "Python module", "Takes NormalisedEvent list(s). For each event, looks up track/artist in Song Dataset. Attaches valence (0-1), arousal (0-1), and other attributes. Flags unmatched tracks; does not drop.")

    Component(cohort_loader, "Cohort Data Loader", "Python module", "Loads reference and demo cohort listening histories with clinical metadata. Caches in memory on first load. Provides comparison data for user and researcher modes.")

    Component(demo_loader, "Demo Dataset Loader", "Python module", "Loads pre-processed demo dataset (10 participants, metadata, enriched events). Used by /api/researcher/demo endpoint for testing.")

    Component(user_serialiser, "User Response Serialiser", "Python module", "Combines enriched single-user events and reference cohort summaries into JSON payload for user frontend.")

    Component(researcher_serialiser, "Researcher Response Serialiser", "Python module", "Combines enriched participant events, metadata, raw-value histograms (age, depression score, engagement), and cohort summary into JSON payload for researcher frontend.")
}

ContainerDb(song_db, "Song Dataset", "Flat files (CSV/XLSX)")
ContainerDb(refdata, "Reference Cohort Data", "Flat files (CSV/XLSX)")
ContainerDb(demo_data, "Demo Researcher Dataset", "Flat files")

Rel(user_router, registry, "Looks up parser by format ID")
Rel(researcher_router, metadata_validator, "Validates metadata CSV")
Rel(researcher_router, registry, "Looks up parsers for participant files")
Rel(metadata_validator, researcher_router, "Returns validated metadata rows")

Rel(registry, spotify_parser, "Instantiates on Spotify format")
Rel(registry, yt_parser, "Instantiates on YT Music format")
Rel(registry, csv_parser, "Instantiates on CSV format")

Rel(spotify_parser, enricher, "Passes NormalisedEvent list")
Rel(yt_parser, enricher, "Passes NormalisedEvent list")
Rel(csv_parser, enricher, "Passes NormalisedEvent list")

Rel(enricher, song_db, "Looks up track attributes by name/artist")
Rel(enricher, user_serialiser, "Enriched user events")
Rel(enricher, researcher_serialiser, "Enriched participant events")

Rel(cohort_loader, refdata, "Reads reference cohort files")
Rel(cohort_loader, user_serialiser, "Cohort summaries")
Rel(cohort_loader, researcher_serialiser, "Cohort summaries")

Rel(demo_loader, demo_data, "Loads demo dataset")
Rel(demo_loader, researcher_serialiser, "Returns demo events + metadata")

@enduml
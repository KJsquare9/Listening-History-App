@startuml C4_Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container Diagram — Listening Analysis System

Person(end_user, "Individual User", "Uploads listening history, views personal insights")
Person(researcher, "Researcher", "Uploads participant data + metadata, filters, analyzes cohorts")

System_Boundary(sys, "Listening Analysis System") {

    Container(user_spa, "User Frontend", "HTML + JS + D3.js", "Single-user mode: file upload, personal mood trajectory, time-series, cohort comparison, listening duration. Receives enriched JSON. Never handles raw attributes.")

    Container(researcher_spa, "Researcher Frontend", "HTML + JS + D3.js", "Multi-user mode: metadata CSV upload, participant file upload, distribution histograms, V-A trajectories with normalized timeline playback (0-100%), field-based filtering.")

    Container(api, "Parse & Enrich API", "Python / Flask", "Stateless API. Routes to correct parser based on file format. Enriches tracks with valence-arousal from song dataset. Handles single-user and researcher endpoints. Returns enriched normalised JSON. Optionally loads demo dataset for researcher testing.")

    ContainerDb(song_db, "Song Dataset", "Flat files (CSV / XLSX)", "Internal dataset: track/artist → valence, arousal, other musical attributes. Read-only at runtime.")

    ContainerDb(refdata, "Cohort Reference Data", "Flat files (CSV / XLSX)", "Listening histories of reference participants + clinical metadata (depression scores, etc). Read-only at runtime.")

    ContainerDb(demo_data, "Demo Researcher Dataset", "Flat files (CSV + participant CSVs)", "Sample 10-participant cohort with metadata.csv (age, gender, depression scores, etc) and listening histories. Used for /api/researcher/demo endpoint.")
}

Rel(end_user, user_spa, "Visits in browser, uploads listening history file", "HTTPS")
Rel(researcher, researcher_spa, "Visits in browser, uploads metadata CSV + participant files", "HTTPS")
Rel(user_spa, api, "POST /api/parse: raw listening history file", "HTTP")
Rel(researcher_spa, api, "GET /api/researcher/demo or POST /api/researcher/process", "HTTP")
Rel(api, user_spa, "Returns enriched user events + cohort summaries", "JSON")
Rel(api, researcher_spa, "Returns enriched participant events, metadata, filtered histograms", "JSON")
Rel(api, song_db, "Looks up track attributes by name / artist", "File I/O")
Rel(api, refdata, "Reads reference cohort data", "File I/O")
Rel(api, demo_data, "Loads demo dataset for testing", "File I/O")

@enduml
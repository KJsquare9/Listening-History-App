@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title System Context — Music Listening Analysis Tool

Person(end_user, "Individual User", "Uploads their own listening history (tracks + timestamps) and views personal psychological visualisations (mood trajectory, time-series, cohort comparison)")
Person(researcher, "Researcher", "Uploads multiple participant listening histories + metadata (demographics, clinical scores). Filters participants, analyzes cohort distributions, compares trajectories with normalized timeline playback.")

System(system, "Listening Analysis System", "Parses user/participant listening histories, enriches with valence-arousal attributes from internal dataset. Renders individual or cohort visualisations with interactive controls.")

System_Ext(spotify, "Spotify Takeout", "External data source — JSON export")
System_Ext(ytmusic, "YT Music Takeout", "External data source — JSON export")
System_Ext(generic, "Generic CSV / TSV", "User-exported listening data in tabular format")

Rel(end_user, system, "Uploads personal listening history file, views personal insights", "HTTPS / browser")
Rel(researcher, system, "Uploads participant metadata CSV + listening history files, filters & analyzes cohort", "HTTPS / browser")
Rel(spotify, end_user, "User downloads their data export")
Rel(ytmusic, end_user, "User downloads their data export")
Rel(generic, end_user, "User prepares CSV export")
Rel(spotify, researcher, "Researcher collects participant data exports")
Rel(ytmusic, researcher, "Researcher collects participant data exports")
Rel(generic, researcher, "Researcher collects participant data exports")

@enduml